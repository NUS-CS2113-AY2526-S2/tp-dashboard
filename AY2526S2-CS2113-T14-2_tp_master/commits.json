s":55,"deletions":0}}},{"hash":"dfeb585d76be4057d47819b31c6362eedcee96a1","isMergeCommit":false,"messageTitle":"Implement income and asset management features: salary, savings, ratio","messageBody":"- Initialise Profile within FinTrackPro main class.\n- Expand handleCommand switch to support salary, savings, and ratio.\n- Implement interactive helper methods that show current values before update.\n- Integrate InputUtil to check inputs before entering handleCommand.\n","fileTypesAndContributionMap":{"functional-code":{"insertions":67,"deletions":20}}},{"hash":"e54452aefa8a2aaea9bd7c26ab2825595f3b50bc","isMergeCommit":false,"messageTitle":"Fix checkstyle indentation in handleCommand switch","messageBody":"","fileTypesAndContributionMap":{"functional-code":{"insertions":19,"deletions":19}}},{"hash":"a4a1f79f72b6d3ff9045632bdfae14bf3970b155","isMergeCommit":false,"messageTitle":"Fix checkstyle","messageBody":"","fileTypesAndContributionMap":{"functional-code":{"insertions":1,"deletions":1}}}]},{"date":"2026-03-01T00:00:00","commitResults":[{"hash":"9a61a942ceb6caa7fa77c53dbe572ca2031b53dd","isMergeCommit":false,"messageTitle":"Add ratio,savings,salary commands into help message","messageBody":"","fileTypesAndContributionMap":{"functional-code":{"insertions":3,"deletions":0}}},{"hash":"b87ac69104d96a8cf83596e59dc9d7e1a4da3b65","isMergeCommit":false,"messageTitle":"Update help message ui with savings,ratio,salary commands","messageBody":"","fileTypesAndContributionMap":{"functional-code":{"insertions":1,"deletions":1}}}]},{"date":"2026-03-02T00:00:00","commitResults":[{"hash":"ae132f3d398a47de215b9bb482fbb681775a1f06","isMergeCommit":false,"messageTitle":"Fix input ratio issues by adding readRatio in InputUtil","messageBody":"","fileTypesAndContributionMap":{"functional-code":{"insertions":37,"deletions":14}}},{"hash":"4d009f9389d41f719216e8b55cecd8a0f1f62f69","isMergeCommit":false,"messageTitle":"Fix input validation logic and refactor Profile to use BigDecimal","messageBody":"Removed hardcoded 0.025 multiplier from InputUtil.readMoney to fix salary/savings bugs.\n\nAdded InputUtil.readRatio with regex and range validation [0, 1].\n\nConverted Profile.contributionRatio from double to BigDecimal for better precision.\n","fileTypesAndContributionMap":{"functional-code":{"insertions":43,"deletions":11}}}]},{"date":"2026-03-03T00:00:00","commitResults":[{"hash":"704cf58298092d943e1033b551316617903f1d18","isMergeCommit":true,"messageTitle":"Merge pull request #10 from AK2003x/fix-input-logic","messageBody":"Fix input logic for readMoney, Add readRatio, moved downpayment calculation logic","fileTypesAndContributionMap":{}}]},{"date":"2026-03-05T00:00:00","commitResults":[{"hash":"01e0d76df3af1d9bd0bdf01244a96214af443ec5","isMergeCommit":false,"messageTitle":"Added details in AboutUs","messageBody":"","fileTypesAndContributionMap":{"docs":{"insertions":3,"deletions":7}}},{"hash":"ee3ecb23fe44ce0233fffd070dd7b2e6dbd353b4","isMergeCommit":false,"messageTitle":"Change name","messageBody":"","fileTypesAndContributionMap":{"docs":{"insertions":3,"deletions":3}}},{"hash":"0c99814a7c176157366805f72ff459dcda96ad55","isMergeCommit":true,"messageTitle":"Merge branch \u0027master\u0027 into Junhao-AboutUs","messageBody":"","fileTypesAndContributionMap":{}},{"hash":"29f489a3ac6ffebd2e1d0533cfe45454a8c61aa7","isMergeCommit":true,"messageTitle":"Merge pull request #17 from AK2003x/Junhao-AboutUs","messageBody":"Added details in AboutUs","fileTypesAndContributionMap":{}}]},{"date":"2026-03-08T00:00:00","commitResults":[{"hash":"61f052a06ff947b48a6a3d99ae665bff113cbc27","isMergeCommit":false,"messageTitle":"Remove salary and ratio editing commands","messageBody":"The bot supports editing salary and ratio within the command loop.\n\nThis level of editing capability is too complex for a V1.0 release.\nStreamlining these variables into a one-time setup reduces the\napplication\u0027s complexity and potential for user error.\n\nLet\u0027s,\n* remove handleSalary and handleRatio from the command switch\n* delete the corresponding handler methods\n* update the help message to reflect these removals\n","fileTypesAndContributionMap":{"functional-code":{"insertions":0,"deletions":48}}},{"hash":"61a5e37b5cc959d8701a1b945b0bf4b9fde95368","isMergeCommit":false,"messageTitle":"Update initial setup and add Javadoc","messageBody":"The onboarding sequence only collects the user\u0027s name, ratio and BTO goal.\n\nThis is insufficient for a V1.0 release where editing commands for\nsavings and salary have been removed. The application needs these\nvalues initialised immediately to ensure the summary report is\naccurate from the first run.\n\nLet\u0027s,\n* update performInitialSetup to prompt for salary and savings\n* add Javadoc to performInitialSetup explaining the initialisation\n\nIntegrating these prompts into the setup ensures all necessary\nfinancial state is captured before entering the command loop.\n","fileTypesAndContributionMap":{"functional-code":{"insertions":28,"deletions":4}}},{"hash":"4e91f1ac4064b4617b2f316b7589db05046d14be","isMergeCommit":false,"messageTitle":"Repurpose savings command to increment total","messageBody":"The savings command overwrites the existing savings value.\n\nUsers must manually calculate their new total when adding funds, which\nis unintuitive and prone to error. In a V1.0 workflow, users are more\nlikely to add incremental surpluses than to redefine their entire net\nworth.\n\nLet\u0027s,\n* update handleSavings to add input amounts to the current balance\n* update success messages to show the deposit and the new total\n* reformat showHelpMessage to group commands and reflect this change\n","fileTypesAndContributionMap":{"functional-code":{"insertions":37,"deletions":19}}},{"hash":"45548d67950ed9ea50bb61d2f9f90cc3a26a1247","isMergeCommit":false,"messageTitle":"Tests: Sync input and expected.txt","messageBody":"Let\u0027s,\n* add monthly salary and current savings to input.txt\n* adjust savings test case to verify incremental addition\n","fileTypesAndContributionMap":{"functional-code":{"insertions":2,"deletions":1}}}]},{"date":"2026-03-09T00:00:00","commitResults":[{"hash":"1c6444c5008984dd7eb175e9dcf1f118913ec5a3","isMergeCommit":true,"messageTitle":"Merge pull request #65 from nicholaslauhy/branch-Level-1","messageBody":"Improve UI","fileTypesAndContributionMap":{}}]},{"date":"2026-03-11T00:00:00","commitResults":[{"hash":"5f1e433f01637e11393bc7f767c4de693f6fae58","isMergeCommit":true,"messageTitle":"Merge pull request #73 from wKynaston/add-Junit","messageBody":"Add junit","fileTypesAndContributionMap":{}},{"hash":"6476358ec36f163d415709fb82a5d32726b75657","isMergeCommit":false,"messageTitle":"Tests: Add unit tests for Profile financial fields (Salary, Savings, Ratio)","messageBody":"Lets\n* implement tests for monthlySalary getters and setters\n* implement tests for currentSavings getters and setters\n* implement tests for contributionRatio getters and setters\n","fileTypesAndContributionMap":{"test-code":{"insertions":38,"deletions":0}}}]}],"nicholaslauhy":[{"date":"2026-02-25T00:00:00","commitResults":[{"hash":"f179f4b5f245df499b6caf6466453d471b9b12f1","isMergeCommit":true,"messageTitle":"Merge pull request #1 from nicholaslauhy/master","messageBody":"Add project description to README","fileTypesAndContributionMap":{}},{"hash":"7d864c5fa4814b3970c37de4a0542febe5c7689e","isMergeCommit":false,"messageTitle":"Add deadline and money calculation","messageBody":"Currently it was just a bare Duke skeleton.\n\nWe needed to change it into our own project,\nwith its own identity and flair.\n\nAdd intro, deadline and legal fee feature\n\nNow, our fintracker has an intro and goodbye,\nand can calculate the deadline and downpayment\n","fileTypesAndContributionMap":{"functional-code":{"insertions":63,"deletions":21},"other":{"insertions":1,"deletions":1}}},{"hash":"114a62973c1cbdac30874016d494aefba8ca9a14","isMergeCommit":false,"messageTitle":"Fix checkstyl